# Git Global Ignore Patterns for IMS

# ============================================
# FRONTEND (Node.js)
# ============================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
frontend/dist/
frontend/build/
frontend/.next/
frontend/out/

# Environment
.env
.env.local
.env.*.local
.env.production

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes

# ============================================
# BACKEND (Python)
# ============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
*.egg-info/
dist/
build/
*.egg

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv
pip-log.txt
pip-delete-this-directory.txt

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Poetry
poetry.lock

# ============================================
# DATABASE
# ============================================

# DynamoDB Local
dynamodb_data/
*.db
*.sqlite
*.sqlite3

# ============================================
# PROJECT SPECIFIC
# ============================================

# Environment files (secrets)
.env
.env.production
.env.development
.env.test

# MacOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp

# Build artifacts
dist/
build/
*.zip
*.tar.gz

# IDE specific
.vscode/
.idea/
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# Git
.gitignore~

# Backup files
*.bak
*.backup
*~

# ============================================
# OPTIONAL IGNORES (Uncomment if needed)
# ============================================

# TypeScript
# *.tsbuildinfo

# Parcel
# .parcel-cache
# .parcel-cache-v2

# Next.js
# .next/
# out/

# Nuxt
# .nuxt/
# dist/

# Vuepress
# .vuepress/dist

# Serverless directories
# .serverless/

# FuseBox cache
# .fusebox/

# DynamoDB Local
# .dynamodb/
